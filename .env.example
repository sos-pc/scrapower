# Scrapower — Environment variables
# Copy to .env and fill in your credentials

# API
SCRAPOWER_API_KEY=sp-xxxxxxxx

# Network
SCRAPOWER_HOST=0.0.0.0
SCRAPOWER_COORDINATOR_URL=https://your-coordinator.example.com
SCRAPOWER_WG_HOST=your-coordinator.example.com
SCRAPOWER_WG_PASS=your_wireguard_password

# Provider enable/disable (true/false)
KAGGLE_ENABLED=true
MODAL_ENABLED=true

# Kaggle accounts — each account can have "enabled": false to skip it
# Format: [{"username": "...", "token": "...", "enabled": true}]
KAGGLE_ACCOUNTS='[
  {"username": "user1", "token": "xxx", "enabled": true},
  {"username": "user2", "token": "yyy", "enabled": false}
]'

# Modal accounts — same format
# Format: [{"token_id": "...", "token_secret": "...", "enabled": true}]
MODAL_ACCOUNTS='[
  {"token_id": "ak-xxx", "token_secret": "as-xxx", "enabled": true}
]'
# Fallback: single account via env vars (if MODAL_ACCOUNTS not set)
# MODAL_TOKEN_ID=ak-xxx
# MODAL_TOKEN_SECRET=as-xxx

# HuggingFace Spaces (CPU worker)
HF_TOKEN=hf_xxx
HF_SPACE_ID=username/space-name
