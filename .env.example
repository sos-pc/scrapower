# Scrapower — environment variables
# Copy to .env and fill in values. NEVER commit .env!

# ── Server ──────────────────────────────────────────
SCRAPOWER_HOST=0.0.0.0
SCRAPOWER_PORT=8777

# ── Security ────────────────────────────────────────
SCRAPOWER_API_KEY=change-me-to-a-random-string
SCRAPOWER_SECRET=change-me-to-another-random-string

# ── OAuth (GitHub worker harvester) ─────────────────
SCRAPOWER_GITHUB_CLIENT_ID=
SCRAPOWER_GITHUB_CLIENT_SECRET=

# ── Coordinator URL ─────────────────────────────────
SCRAPOWER_COORDINATOR_URL=https://scrapower.talos-int.com

# ── Workers ─────────────────────────────────────────
# Disable embedded worker (set to 0 when using external workers only)
SCRAPOWER_EMBEDDED_WORKER=0
# Disable WebSocket task assignment when Mode B (HTTP pull) is primary
SCRAPOWER_WS_ASSIGN_ENABLED=false

# ── Kaggle Harvester ────────────────────────────────
# JSON array of {username, token} objects
KAGGLE_ACCOUNTS=[{"username":"your-account","token":"KGAT_xxx"}]

# ── YouTube Cookies ─────────────────────────────────
# SHA-256 hash of a blob containing Netscape-format cookies
# Export with "Get cookies.txt LOCALLY" browser extension
SCRAPOWER_YT_COOKIES_HASH=

# ── Modal (GPU workers) ─────────────────────────────
# Token from modal.com → Settings → API Tokens
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=
# JSON array of {token_id, token_secret} for multi-account (like KAGGLE_ACCOUNTS)
# MODAL_ACCOUNTS=[{"token_id":"ak-xxx","token_secret":"as-xxx"}]

# ── VPN (CyberGhost) ────────────────────────────────
# OpenVPN config and certs in deploy/vpn/
SCRAPOWER_VPN_PROXY=socks5://127.0.0.1:1080
SCRAPOWER_VPN_USER=your-cyberghost-username
SCRAPOWER_VPN_PASS=your-cyberghost-password
