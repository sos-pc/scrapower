# Scrapower secrets — copy to .env and fill in values
# NEVER commit .env to version control

# Server
SCRAPOWER_HOST=0.0.0.0
SCRAPOWER_PORT=8777

# Security
SCRAPOWER_API_KEY=change-me-to-a-random-64-char-string
SCRAPOWER_SECRET=change-me-to-a-random-passphrase

# GitHub OAuth (for visitor workers)
SCRAPOWER_GITHUB_CLIENT_ID=
SCRAPOWER_GITHUB_CLIENT_SECRET=

# Coordinator URL (used for OAuth callback)
SCRAPOWER_COORDINATOR_URL=https://scrapower.talos-int.com

# GitHub Actions harvester (optional)
# SCRAPOWER_GH_TEMPLATE=sos-pc/scrapower
