async def _any_worker_can_download(db) -> bool:
    """Check if any connected worker has ip_reputation != datacenter."""
    # Via les sessions WS actives
    import scrapower.coordinator.worker_gateway.router as rmod
    sm = getattr(rmod, "session_manager", None)
    if sm:
        for s in sm.active_sessions:
            rep = s.capabilities.get("network", {}).get("ip_reputation", "datacenter")
            if rep != "datacenter":
