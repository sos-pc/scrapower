                    """UPDATE tasks SET state = ?, updated_at = ?
                       WHERE id = ? AND state = ?""",
                    (TaskState.FAILED, str(now), task_id, task.state),
                )
        else:
            cursor = await self._db.execute(
                "UPDATE tasks SET state = ?, updated_at = ? WHERE id = ? AND state = ?",
