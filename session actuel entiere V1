        if account:
            os.environ["MODAL_TOKEN_ID"] = account.get("token_id", "")
            os.environ["MODAL_TOKEN_SECRET"] = account.get("token_secret", "")
        return await modal.billing.workspace_billing_report.aio(
            start=start, end=end, resolution="d"
