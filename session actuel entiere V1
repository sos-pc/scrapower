# TEMPLATE UNIVERSEL — worker éphémère Scrapower
# Utilisé par : Modal (deploy/modal/worker.py)
#              Kaggle (deploy/kaggle/sworker.ipynb)
#              HF Spaces (deploy/hf-spaces/app.py)
# ═══════════════════════════════════════════════════════════════

import asyncio, hashlib, json, os, time, uuid
import aiohttp

# ── Config (injectée par le harvester ou l'environnement) ──
COORDINATOR_URL = os.environ["COORDINATOR_URL"]
WORKER_ID = f"{os.environ.get('WORKER_PREFIX','worker')}-{uuid.uuid4().hex[:8]}"
POLL_INTERVAL_SEC = 3
IDLE_TIMEOUT_SEC = 300
HEARTBEAT_INTERVAL_SEC = 30

# ── Log buffer (flushé à chaque heartbeat et pull) ──
_LOG_BUF: list[str] = []

def log(msg: str) -> None:
    line = f"{time.strftime('%H:%M:%S')} {msg}"
    _LOG_BUF.append(line)
    if len(_LOG_BUF) > 200:
        del _LOG_BUF[:-100]
    print(line)

def drain_logs() -> str:
    if not _LOG_BUF:
        return ""
    chunk = "\n".join(_LOG_BUF[-50:])
    _LOG_BUF.clear()
    return chunk

# ── Heartbeat (annulé quand la tâche est finie) ──
async def _heartbeat(session, task_id: str, token: str):
    """Tant que task_id est set, envoie heartbeat + logs toutes les 30s."""
    while task_id:
        await asyncio.sleep(HEARTBEAT_INTERVAL_SEC)
        logs = drain_logs()
        try:
            async with session.post(
                f"{COORDINATOR_URL}/worker/heartbeat",
                json={"type": "heartbeat", "task_id": task_id,
                      "assignment_token": token, "logs": logs},
                timeout=aiohttp.ClientTimeout(total=10),
            ) as r:
                ack = await r.json()
                if not ack.get("task_valid"):
                    log("TASK REASSIGNED — aborting")
                    raise TaskReassignedError()
        except TaskReassignedError:
            raise
        except Exception:
            pass  # heartbeat best-effort

class TaskReassignedError(Exception):
    pass

# ── Execute (spécifique au runtime : wasm ou python) ──
def execute(runtime: str, executable: bytes, input_data: bytes):
    """Point d'extension : chaque worker définit sa fonction execute()."""
    raise NotImplementedError

# ── Boucle principale ──
async def run_worker():
    last_task_time = time.time()
    async with aiohttp.ClientSession() as session:
        while True:
            # ─── PULL ───────────────────────────────────
            logs = drain_logs()
            try:
                async with session.post(
                    f"{COORDINATOR_URL}/worker/pull",
                    json={"type": "pull", "worker_id": WORKER_ID,
                          "capabilities": CAPABILITIES, "logs": logs},
                    timeout=aiohttp.ClientTimeout(total=10),
                ) as r:
                    data = await r.json()
            except Exception as e:
                log(f"Pull failed: {e}")
                await asyncio.sleep(POLL_INTERVAL_SEC)
                continue

            task = data.get("task")
            if not task:
                if time.time() - last_task_time > IDLE_TIMEOUT_SEC:
                    log(f"Idle {IDLE_TIMEOUT_SEC}s → stopping")
                    break
                await asyncio.sleep(POLL_INTERVAL_SEC)
                continue

            last_task_time = time.time()
            tid, tok, rt = task["id"], task["assignment_token"], task.get("runtime", "wasm")
            log(f"Task {tid[:12]} (runtime={rt})")

            # ─── DOWNLOAD BLOBS ─────────────────────────
            try:
                async with session.get(f"{COORDINATOR_URL}/blobs/{task['payload']['executable_hash']}") as r:
                    executable = await r.read()
                async with session.get(f"{COORDINATOR_URL}/blobs/{task['payload']['input_hash']}") as r:
                    input_data = await r.read()
            except Exception as e:
                log(f"Download failed: {e}")
                continue

            # ─── EXECUTE + HEARTBEAT ─────────────────────
            hb_task = asyncio.create_task(_heartbeat(session, tid, tok))
            try:
                output, output_hash, exit_code, stderr = execute(rt, executable, input_data)
            except TaskReassignedError:
                continue  # go back to pull
            except Exception as e:
                output, output_hash, exit_code = b"", "", 1
                stderr = f"{type(e).__name__}: {e}"
                log(f"Error: {stderr}")
            finally:
                hb_task.cancel()
                try:
                    await hb_task
                except (asyncio.CancelledError, TaskReassignedError):
                    pass

            if exit_code != 0:
                log(f"Task failed: exit_code={exit_code}")
            else:
                log(f"OK: {output_hash[:12]}...")

            # ─── UPLOAD + SUBMIT ─────────────────────────
            try:
                async with session.put(
                    f"{COORDINATOR_URL}/blobs?assignment_token={tok}",
                    data=output, timeout=aiohttp.ClientTimeout(total=30),
                ) as r:
                    up = await r.json()
                if not output_hash:
                    output_hash = up.get("hash", "")
            except Exception as e:
                log(f"Upload failed: {e}")
                continue

            try:
                async with session.post(
                    f"{COORDINATOR_URL}/worker/submit",
                    json={"type": "submit", "task_id": task["id"],
                          "assignment_token": tok,
                          "result": {"output_hash": output_hash,
                                     "execution_metadata": {"exit_code": exit_code, "stderr": stderr}}},
                    timeout=aiohttp.ClientTimeout(total=10),
                ) as r:
                    ack = await r.json()
                if ack.get("accepted"):
                    log(f"Submit accepted ✓")
            except Exception as e:
                log(f"Submit failed: {e}")

            await asyncio.sleep(POLL_INTERVAL_SEC)
