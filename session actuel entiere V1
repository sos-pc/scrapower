# Deploy: docker compose up -d --build
# Logs:   docker compose logs -f

services:
  coordinator:
    build: .
    network_mode: host
    restart: unless-stopped
    volumes:
      - ./data:/app/data
      - ./deploy:/app/deploy:ro
      - ./src:/app/src:ro
    environment:
      - SCRAPOWER_HOST=0.0.0.0
      - SCRAPOWER_DATA_DIR=/app/data
      - SCRAPOWER_VPN_PROXY=socks5://127.0.0.1:1080
      - SCRAPOWER_WG_PROXY=socks5://scrapower:${SCRAPOWER_WG_PASS}@127.0.0.1:1081
      - SCRAPOWER_WG_PROXY_PUBLIC=socks5://scrapower:${SCRAPOWER_WG_PASS}@${SCRAPOWER_WG_HOST:-localhost}:1081
    env_file:
      - .env
    read_only: true
    tmpfs:
      - /tmp:noexec,nosuid,size=512M
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    cap_add:
      - NET_BIND_SERVICE
    depends_on:
      - vpn
      - vpn-wg

  vpn:
    build: ./deploy/vpn
    restart: unless-stopped
    ports:
      - "127.0.0.1:1080:1080"
    cap_add:
      - NET_ADMIN
    devices:
      - /dev/net/tun:/dev/net/tun
    environment:
      - VPN_USER=${SCRAPOWER_VPN_USER:-}
      - VPN_PASS=${SCRAPOWER_VPN_PASS:-}

  vpn-wg:
    build: ./deploy/vpn-wg
    restart: unless-stopped
    privileged: true # needed for WireGuard sysctl on Oracle kernel
    ports:
      - "1081:1081" # SOCKS5 proxy (authenticated, for coordinator + workers)
    cap_add:
      - NET_ADMIN
    sysctls:
      - net.ipv4.conf.all.src_valid_mark=1
      - net.ipv6.conf.all.disable_ipv6=0
    devices:
      - /dev/net/tun:/dev/net/tun
    volumes:
      - ./deploy/vpn-wg/SCRAPOWER.conf:/etc/wireguard/wg0.conf:ro
    environment:
      - SOCKS_USER=${SCRAPOWER_WG_USER:-}
      - SOCKS_PASS=${SCRAPOWER_WG_PASS:-}

