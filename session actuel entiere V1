async def requeue_stale(self, heartbeat_timeout_sec=90):
    """Deux modes selon le type de worker.

    - Workers avec heartbeat : timeout court (90s), assigned_at
      est reset à chaque heartbeat/pull/submit.
    - Workers sans heartbeat : utilise le deadline_ms natif de la
      tâche (900s pour whisper). Le pull/submit reset assigned_at,
      donc seule l'exécution entre pull et submit est non couverte.
    """
    now = time.time()
    
    # Passe 1 : workers avec heartbeat → timeout court
    cursor = await db.execute("""
        SELECT t.id, t.deadline_ms, t.assigned_at, t.assigned_worker_id
        FROM tasks t
        WHERE t.state = 'ASSIGNED'
    """)
    
    async for row in cursor:
        # Vérifier si le worker a la capacité heartbeat
        worker_has_heartbeat = await self._worker_supports_heartbeat(
            row["assigned_worker_id"]
        )
        
        if worker_has_heartbeat:
            timeout = heartbeat_timeout_sec  # 90s
        else:
            timeout = max(300, (row["deadline_ms"] or 60000) / 1000)  # 900s
        
        if now - float(row["assigned_at"] or 0) >= timeout:
            # Atomic update pour éviter TOCTOU
            cursor2 = await db.execute(
                """UPDATE tasks SET state = 'TIMEOUT', updated_at = ?
                   WHERE id = ? AND state = 'ASSIGNED'
                   AND assigned_at < ?""",
                (str(now), row["id"], str(now - timeout)),
            )
            if cursor2.rowcount > 0:
                count += 1
