    },
    TaskState.DOWNLOADING: {TaskState.QUEUED, TaskState.FAILED, TaskState.PENDING},
    TaskState.QUEUED: {TaskState.ASSIGNED, TaskState.CANCELLED},
    TaskState.ASSIGNED: {
        TaskState.COMPLETED,
        TaskState.TIMEOUT,
        TaskState.FAILED,
        TaskState.CANCELLED,
